# ── Required ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Corporate SSL / Zscaler Configuration ──────────────────────────────────────
# Zscaler intercepts HTTPS traffic and re-signs with its own CA certificate.
# Python's bundled certificate store does not trust the Zscaler CA by default,
# which causes: SSLError: [SSL: CERTIFICATE_VERIFY_FAILED]
#
# FIX OPTION 1 (Recommended): Point to your corporate CA bundle
#   Export the Zscaler root certificate from your browser or ask your IT team.
#   Save it as a .crt or .pem file and set the path below.
#
REQUESTS_CA_BUNDLE=/path/to/zscaler-ca.crt
# SSL_CERT_FILE=/path/to/zscaler-ca.crt   # alternative name, same effect
# CURL_CA_BUNDLE=/path/to/zscaler-ca.crt  # used by curl-based tools

# FIX OPTION 2: Disable SSL verification entirely (NOT recommended for production)
# Only use this for local testing when you cannot obtain the CA cert.
#
# DISABLE_SSL_VERIFY=false

# FIX OPTION 3: Trust system certificate store (macOS/Windows — Zscaler auto-installs its CA)
#
# USE_SYSTEM_CERTS=true

# ── Corporate Proxy (if applicable) ────────────────────────────────────────────
# HTTP_PROXY=http://proxy.corp.example.com:8080
# HTTPS_PROXY=http://proxy.corp.example.com:8080
# NO_PROXY=localhost,127.0.0.1,.corp.example.com
